# ────────────────────────────────────────────────────────────────────────────────
# SovereignID — Environment Configuration
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────────────────────

# ─── Backend ──────────────────────────────────────────────────────────────────
SOVEREIGNID_DEBUG=true
SOVEREIGNID_DATABASE_URL=sqlite+aiosqlite:///./sovereignid.db

# ─── Bittensor ────────────────────────────────────────────────────────────────
SOVEREIGNID_BITTENSOR_NETWORK=local
SOVEREIGNID_BITTENSOR_NETUID=1
SOVEREIGNID_BITTENSOR_WALLET_NAME=sovereignid
SOVEREIGNID_BITTENSOR_WALLET_HOTKEY=default
SOVEREIGNID_SUBTENSOR_ENDPOINT=ws://subtensor:9945

# ─── Passport / Holonym ──────────────────────────────────────────────────────
SOVEREIGNID_PASSPORT_API_URL=https://api.holonym.io
SOVEREIGNID_PASSPORT_ACTION_ID=123456789
SOVEREIGNID_PASSPORT_NETWORK=optimism

# ─── Unbrowse ────────────────────────────────────────────────────────────────
SOVEREIGNID_UNBROWSE_API_URL=https://beta-api.unbrowse.ai
SOVEREIGNID_UNBROWSE_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
SOVEREIGNID_HOST=0.0.0.0
SOVEREIGNID_PORT=8000
SOVEREIGNID_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
SOVEREIGNID_JWT_SECRET=change-this-to-a-random-secret-in-production

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
